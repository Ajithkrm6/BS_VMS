# API Configuration
VITE_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# Environment
VITE_APP_ENV=development
VITE_APP_NAME=Bridge Talent

# Debug & Development
VITE_ENABLE_DEBUG=false
VITE_DEBUG_FEATURE_FLAGS=false

# Feature Flags (overrides default config)
# Format: VITE_FF_FEATURENAME=true/false
VITE_FF_AUTHENTICATION=true
VITE_FF_RECRUITING_MANAGEMENT=true
VITE_FF_MAINTENANCE_TRACKING=true
VITE_FF_ADVANCED_REPORTING=false
VITE_FF_DARK_MODE=true
VITE_FF_REAL_TIME_UPDATES=false
VITE_FF_NOTIFICATION_SYSTEM=true
VITE_FF_EXPORT_FEATURE=true
VITE_FF_MULTI_LANGUAGE=false

# Module Configuration
VITE_MODULE_LOADING=lazy
# lazy: Load modules on demand
# eager: Load all modules immediately
# selective: Load only enabled modules

# Feature Flag Rollout Percentages
# 0-100 for gradual rollout
VITE_FF_REPORTING_ROLLOUT=50
VITE_FF_REAL_TIME_ROLLOUT=25
